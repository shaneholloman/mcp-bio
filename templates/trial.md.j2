{% if outcomes.secondary -%}
### Secondary
{% for o in outcomes.secondary -%}
{{ loop.index }}. **{{ o.measure }}**{% if o.description %} - {{ o.description }}{% endif %}{% if o.time_frame %} *Time frame: {{ o.time_frame }}*{% endif %}
{% endfor -%}
{% endif -%}
{% endif -%}
