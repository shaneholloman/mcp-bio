              "myDiseaseInfo": {
                "doDef": "A cell type cancer that has_material_basis_in abnormally proliferating cells derives_from melanocytes which are found in skin, the bowel and the eye.",
                "icdo": "8720/3",
                "mesh": "D008545",
                "mondoId": "MONDO:0005105",
