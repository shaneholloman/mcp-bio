                  "C3224"
                ]
              },
              "name": "Melanoma"
            },
            "evidenceDirection": "SUPPORTS",
            "evidenceLevel": "B",
            "evidenceRating": 5,
            "evidenceType": "PREDICTIVE",
            "flagged": false,
            "id": 95,
            "molecularProfile": {
